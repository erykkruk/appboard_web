# Server-side base URL of the AppBoard Backend.
#
# Used by:
#   - the Next.js /api/* proxy rewrite (see next.config.ts) — every request
#     the admin panel makes to /api/* is forwarded here
#   - SSR Better Auth calls (see src/lib/auth-client.ts) when running on the server
#
# Defaults to http://localhost:6680, so you do NOT need to set this for local
# development with a backend on the default port. Self-hosters running the
# backend on a different host/port should override it, e.g.:
#   BACKEND_URL=https://api.appboard.example.com
BACKEND_URL=http://localhost:6680
